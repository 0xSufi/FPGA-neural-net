// Physical constraints for top_ocr on Tang Primer 25K (GW5A-LV25MG121).
// Display pins use Sipeed's validated PMOD_DTx2 mapping (pmod_digitalTube-2bit,
// "slot A"): sel=K5, seg[6:0]=L11,K11,L5,E10,E11,A11,A10. Plug the tube into
// that slot (verified: rolling 00..99 counter displays correctly there).

// ---- clock / reset ----
IO_LOC "clk" E2;
IO_PORT "clk" IO_TYPE=LVCMOS33 PULL_MODE=DOWN BANK_VCCIO=3.3;
IO_LOC "rst" H11;
IO_PORT "rst" IO_TYPE=LVCMOS33 PULL_MODE=DOWN BANK_VCCIO=3.3;

// ---- USB serial (to BL616/FT2232) ----
IO_LOC "uart_rx" B3;
IO_PORT "uart_rx" IO_TYPE=LVCMOS33 PULL_MODE=NONE BANK_VCCIO=3.3;
IO_LOC "uart_tx" C3;
IO_PORT "uart_tx" IO_TYPE=LVCMOS33 PULL_MODE=NONE DRIVE=8 BANK_VCCIO=3.3;

// ---- PMOD_DTx2 two-digit 7-segment (slot A, vendor mapping) ----
IO_LOC "sel" K5;
IO_PORT "sel" PULL_MODE=NONE DRIVE=8 BANK_VCCIO=3.3;
IO_LOC "seg[6]" L11;
IO_PORT "seg[6]" PULL_MODE=NONE DRIVE=8 BANK_VCCIO=3.3;
IO_LOC "seg[5]" K11;
IO_PORT "seg[5]" PULL_MODE=NONE DRIVE=8 BANK_VCCIO=3.3;
IO_LOC "seg[4]" L5;
IO_PORT "seg[4]" PULL_MODE=NONE DRIVE=8 BANK_VCCIO=3.3;
IO_LOC "seg[3]" E10;
IO_PORT "seg[3]" PULL_MODE=NONE DRIVE=8 BANK_VCCIO=3.3;
IO_LOC "seg[2]" E11;
IO_PORT "seg[2]" PULL_MODE=NONE DRIVE=8 BANK_VCCIO=3.3;
IO_LOC "seg[1]" A11;
IO_PORT "seg[1]" PULL_MODE=NONE DRIVE=8 BANK_VCCIO=3.3;
IO_LOC "seg[0]" A10;
IO_PORT "seg[0]" PULL_MODE=NONE DRIVE=8 BANK_VCCIO=3.3;

// ---- PMOD_LEDx8 on slot B (group B pins, active low) ----
IO_LOC "o_ledb[7]" C10;
IO_PORT "o_ledb[7]" PULL_MODE=NONE DRIVE=8 BANK_VCCIO=3.3;
IO_LOC "o_ledb[6]" C11;
IO_PORT "o_ledb[6]" PULL_MODE=NONE DRIVE=8 BANK_VCCIO=3.3;
IO_LOC "o_ledb[5]" B10;
IO_PORT "o_ledb[5]" PULL_MODE=NONE DRIVE=8 BANK_VCCIO=3.3;
IO_LOC "o_ledb[4]" B11;
IO_PORT "o_ledb[4]" PULL_MODE=NONE DRIVE=8 BANK_VCCIO=3.3;
IO_LOC "o_ledb[3]" D10;
IO_PORT "o_ledb[3]" PULL_MODE=NONE DRIVE=8 BANK_VCCIO=3.3;
IO_LOC "o_ledb[2]" D11;
IO_PORT "o_ledb[2]" PULL_MODE=NONE DRIVE=8 BANK_VCCIO=3.3;
IO_LOC "o_ledb[1]" G10;
IO_PORT "o_ledb[1]" PULL_MODE=NONE DRIVE=8 BANK_VCCIO=3.3;
IO_LOC "o_ledb[0]" G11;
IO_PORT "o_ledb[0]" PULL_MODE=NONE DRIVE=8 BANK_VCCIO=3.3;

// ---- PMOD_LEDx8 on slot C (group C pins, active low) ----
IO_LOC "o_ledc[7]" H5;
IO_PORT "o_ledc[7]" PULL_MODE=NONE DRIVE=8 BANK_VCCIO=3.3;
IO_LOC "o_ledc[6]" H8;
IO_PORT "o_ledc[6]" PULL_MODE=NONE DRIVE=8 BANK_VCCIO=3.3;
IO_LOC "o_ledc[5]" G8;
IO_PORT "o_ledc[5]" PULL_MODE=NONE DRIVE=8 BANK_VCCIO=3.3;
IO_LOC "o_ledc[4]" G5;
IO_PORT "o_ledc[4]" PULL_MODE=NONE DRIVE=8 BANK_VCCIO=3.3;
IO_LOC "o_ledc[3]" J5;
IO_PORT "o_ledc[3]" PULL_MODE=NONE DRIVE=8 BANK_VCCIO=3.3;
IO_LOC "o_ledc[2]" H7;
IO_PORT "o_ledc[2]" PULL_MODE=NONE DRIVE=8 BANK_VCCIO=3.3;
IO_LOC "o_ledc[1]" G7;
IO_PORT "o_ledc[1]" PULL_MODE=NONE DRIVE=8 BANK_VCCIO=3.3;
IO_LOC "o_ledc[0]" F5;
IO_PORT "o_ledc[0]" PULL_MODE=NONE DRIVE=8 BANK_VCCIO=3.3;
